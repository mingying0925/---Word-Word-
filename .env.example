# SkillBridge 环境变量配置示例
# 复制此文件为 .env 并修改为实际值

# 数据库配置
DB_USERNAME=skillbridge
DB_PASSWORD=skillbridge_pass
MYSQL_ROOT_PASSWORD=root_pass

# JWT 密钥（必须 >= 32 字节，生产环境务必修改）
JWT_SECRET=SkillBridgeProductionSecretKey2026ChangeMe

# 敏感数据加密密钥（AES-256-GCM）
CRYPTO_SECRET=SkillBridgeCryptoSecret2026ChangeMe

# 默认教师账号（首次启动自动创建，生产环境务必修改密码）
TEACHER_DEFAULT_ID=admin
TEACHER_DEFAULT_PASSWORD=ChangeMe123!
